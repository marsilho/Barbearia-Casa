const cards = document.querySelector('.depoimentos-cards');

let scroll = 0;

function carousel() {
    scroll += 1;

    cards.style.transform = `translateX(-${scroll}px)`;
    cards.style.transition = '1s linear';

    // quando chegar no final volta pro começo
    if (scroll >= 1000) {
        scroll = 0;
    }
}

setInterval(carousel, 30);